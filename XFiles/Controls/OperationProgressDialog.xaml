<UserControl
    x:Class="XFiles.Controls.OperationProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="1100"
                MinWidth="800"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="32,24">

            <StackPanel>
                <!-- Operation title -->
                <TextBlock x:Name="TitleText"
                           Foreground="{StaticResource XFilesAccentBrush}"
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                           FontSize="18"
                           Margin="0,0,0,14"
                           Text="" />

                <!-- Source -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="From:"
                               Foreground="#66FFFFFF"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="SourceText"
                               Foreground="{StaticResource XFilesForegroundBrush}"
                               FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                                 MaxWidth="1050"
                                VerticalAlignment="Center"
                                Text="" />
                </StackPanel>

                <!-- Destination -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="To:"
                               Foreground="#66FFFFFF"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="DestText"
                               Foreground="{StaticResource XFilesForegroundBrush}"
                               FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="1580"
                               VerticalAlignment="Center"
                               Text="" />
                </StackPanel>

                <!-- Progress bar -->
                <ProgressBar x:Name="ProgressBar"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Height="28"
                             Margin="0,0,0,10" />

                <!-- Current file -->
                <TextBlock x:Name="CurrentFileText"
                           Foreground="#99FFFFFF"
                           FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Text="" />

                <!-- Bytes info -->
                <TextBlock x:Name="BytesText"
                           Foreground="#66FFFFFF"
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                           FontSize="12"
                           Margin="0,4,0,0"
                           Text="" />

                <!-- Cancel hint -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                           Width="14" Height="14" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Cancel"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="11"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
