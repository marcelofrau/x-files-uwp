                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/lr/button_xbox_digital_bumper_light_1.png"
                           Width="16" Height="16" Margin="0,0,2,0" VerticalAlignment="Center" />
                    <Image Source="ms-appx:///Assets/GamepadButtons/lr/button_xbox_digital_bumper_light_2.png"
                           Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Center" />
