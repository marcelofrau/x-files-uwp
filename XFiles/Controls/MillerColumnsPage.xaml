                        <Border Background="#252830" Height="1"
                                HorizontalAlignment="Center" Width="160"
                                Margin="0,14,0,12" />

                        <!-- Links -->
                        <TextBlock Text="PROJECT"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                   FontSize="10" Foreground="#55FFFFFF"
                                   HorizontalAlignment="Center"
                                   CharacterSpacing="80" Margin="0,0,0,6" />

                        <HyperlinkButton x:Name="AboutGithubLink"
                                         NavigateUri="https://github.com/marcelofrau/x-files-uwp"
                                         HorizontalAlignment="Center"
                                         Margin="0,0,0,4">
                            <TextBlock Text="github.com/marcelofrau/x-files-uwp"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                       FontSize="12" Foreground="#FF58A6FF" />
