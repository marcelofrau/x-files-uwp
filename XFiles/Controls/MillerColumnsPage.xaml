<Page
    x:Class="XFiles.Controls.MillerColumnsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XFiles.Controls"
    Background="#0D1117"
    IsTabStop="True">

    <Grid>
        <!-- Main layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Background="#284325" Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="ms-appx:///Assets/logo.png"
                   Height="24"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center" />

            <TextBlock Grid.Column="2"
                       x:Name="VersionText"
                       Text=""
                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                       FontSize="10"
                       Foreground="{StaticResource XFilesTextDimBrush}"
                       Margin="0,0,4,0"
                       VerticalAlignment="Top" />
        </Grid>

        <!-- ═══ COLUMNS ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="25*" />
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="40*" />
            </Grid.ColumnDefinitions>

            <!-- Parent column (left) -->
            <Grid Grid.Column="0" x:Name="ParentColumn" Background="#0F1318"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ParentColumnSlide" X="0" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:MarqueeTextBlock Grid.Row="0"
                    x:Name="ParentHeader"
                    Text=""
                    Foreground="{StaticResource XFilesAccentBrush}"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                    FontSize="14"
                    Padding="12,8,12,4" />

                <ListView Grid.Row="1"
                    x:Name="ParentList"
                    Padding="0"
                    Style="{StaticResource RetroListViewStyle}"
                    ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                    IsHitTestVisible="False"
                    Opacity="0.6">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="12,3,12,3">
                                <Image Source="{Binding Icon}"
                                       Width="18" Height="18"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource XFilesTextMutedBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="14"
                                           Margin="0,3,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Grid.Row="2"
                    x:Name="ParentStatus"
                    Text=""
                    Foreground="{StaticResource XFilesTextDimBrush}"
                    FontSize="12"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                    Padding="12,6,12,6" />

                <!-- Welcome panel — shown at root (no parent) -->
                <Grid x:Name="WelcomePanel" Grid.Row="0" Grid.RowSpan="3"
                      Visibility="Collapsed" Background="#0F1318">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center"
                                Margin="0,36,0,0">
                        <Image Source="ms-appx:///Assets/logo.png"
                               Height="56" HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                        <TextBlock Text="Gamepad Driven Filebrowser"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="11" Foreground="#66FFFFFF"
                                   HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Tagline -->
                    <TextBlock Grid.Row="1"
                               Text="Browse files and folders&#x0a;with your gamepad"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="13" Foreground="#66FFFFFF"
                               TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="16,0,16,0" />

                    <!-- File type icons row -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,20">
                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/ctx-folder-120.png"
                               Width="28" Height="28" Margin="0,0,6,0" Opacity="0.5" />
                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/ctx-image-120.png"
                               Width="28" Height="28" Margin="0,0,6,0" Opacity="0.5" />
                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/ctx-video-120.png"
                               Width="28" Height="28" Margin="0,0,6,0" Opacity="0.5" />
                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/ctx-audio-120.png"
                               Width="28" Height="28" Margin="0,0,6,0" Opacity="0.5" />
                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/ctx-text-120.png"
                               Width="28" Height="28" Margin="0,0,6,0" Opacity="0.5" />
                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/ctx-archive-120.png"
                               Width="28" Height="28" Opacity="0.5" />
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Current column (center) — has focus -->
            <Grid Grid.Column="1" x:Name="CurrentColumn" Background="#141820"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="CurrentColumnSlide" X="0" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:MarqueeTextBlock Grid.Row="0"
                    x:Name="CurrentHeader"
                    Text=""
                    Foreground="{StaticResource XFilesAccentBrush}"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                    FontSize="14"
                    Padding="12,8,12,4" />

                <controls:RetroListView Grid.Row="1"
                    x:Name="CurrentList"
                    Padding="0"
                    Style="{StaticResource RetroListViewStyle}"
                    ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                    SelectionChanged="CurrentList_SelectionChanged"
                    KeyDown="CurrentList_KeyDown">
                    <controls:RetroListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,3,12,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0"
                                       Source="{Binding Icon}"
                                       Width="20" Height="20"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <controls:MarqueeTextBlock Grid.Column="1"
                                           x:Name="ItemNameText"
                                           Text="{Binding Name}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="15"
                                           Margin="0,3,0,0"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SizeDisplay}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="11"
                                           Margin="12,3,0,0"
                                           Foreground="{StaticResource XFilesTextDimBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </controls:RetroListView.ItemTemplate>
                </controls:RetroListView>

                <!-- Loading indicator for current column -->
                <StackPanel Grid.Row="1"
                    x:Name="CurrentLoading"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
                    <ProgressRing IsActive="True" Width="32" Height="32"
                                  Foreground="{StaticResource XFilesAccentBrush}" />
                    <TextBlock Text="Loading..."
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="14"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                    x:Name="CurrentStatus"
                    Text=""
                    Foreground="{StaticResource XFilesTextDimBrush}"
                    FontSize="12"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                    Padding="12,6,12,6" />
            </Grid>

            <!-- Preview column (right) -->
            <Grid Grid.Column="2" x:Name="PreviewColumn" Background="#0F1318"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="PreviewColumnSlide" X="0" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:MarqueeTextBlock Grid.Row="0"
                    x:Name="PreviewHeader"
                    Text=""
                    Foreground="{StaticResource XFilesAccentBrush}"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                    FontSize="14"
                    Padding="12,8,12,4"
                    Marquee="True" />

                <!-- Preview content: folder listing -->
                <ListView Grid.Row="1"
                    x:Name="PreviewList"
                    Padding="0"
                    Style="{StaticResource RetroListViewStyle}"
                    ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                    IsHitTestVisible="False"
                    Opacity="0.7">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="12,3,12,3">
                                <Image Source="{Binding Icon}"
                                       Width="18" Height="18"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource XFilesTextMutedBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="14"
                                           Margin="0,3,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Preview content: text file (plain) -->
                <ScrollViewer Grid.Row="1"
                    x:Name="PreviewTextScroll"
                    Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    Padding="12,8">
                    <TextBlock x:Name="PreviewTextBlock"
                        FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                        FontSize="12"
                        Foreground="#CCCCCC"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                </ScrollViewer>

                <!-- Preview content: source code (syntax highlighted) -->
                <WebView Grid.Row="1"
                    x:Name="PreviewCodeView"
                    DefaultBackgroundColor="#0F1318"
                    Visibility="Collapsed" />

                <!-- Preview content: image file -->
                <Grid Grid.Row="1"
                    x:Name="PreviewImagePanel"
                    Visibility="Collapsed"
                    Background="#0F1318">
                    <Image x:Name="PreviewImage"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform" />
                </Grid>

                <!-- Preview content: audio/video -->
                <Grid Grid.Row="1"
                    x:Name="PreviewMediaPanel"
                    Visibility="Collapsed"
                    Background="#0F1318">
                    <controls:MediaPreviewControl x:Name="MediaPreview" />
                </Grid>

                <!-- Preview content: error -->
                <Grid Grid.Row="1"
                    x:Name="PreviewErrorPanel"
                    Visibility="Collapsed">
                    <TextBlock x:Name="PreviewErrorText"
                        Foreground="{StaticResource XFilesDangerBrush}"
                        FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                        FontSize="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        Padding="16" />
                </Grid>

                <!-- Preview content: unsupported file type -->
                <Grid Grid.Row="1"
                    x:Name="PreviewUnsupportedPanel"
                    Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="PreviewUnsupportedType"
                            Foreground="{StaticResource XFilesTextMutedBrush}"
                            FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                            FontSize="16"
                            HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewUnsupportedSize"
                            Foreground="{StaticResource XFilesTextDimBrush}"
                            FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                    x:Name="PreviewStatus"
                    Text=""
                    Foreground="{StaticResource XFilesTextDimBrush}"
                    FontSize="12"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                    Padding="12,6,12,6" />

                <!-- Quick reference panel — shown at root (no parent) -->
                <Grid x:Name="QuickRefPanel" Grid.Row="0" Grid.RowSpan="3"
                      Visibility="Collapsed" Background="#0F1318" Opacity="0.8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,24,20,24">
                            <!-- Title -->
                            <TextBlock Text="QUICK REFERENCE"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       FontSize="13" Foreground="{StaticResource XFilesAccentBrush}"
                                       Margin="0,0,0,16" />

                            <!-- Navigation -->
                            <TextBlock Text="NAVIGATION"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       FontSize="11" Foreground="{StaticResource XFilesTextMutedBrush}"
                                       Margin="0,0,0,8" />

                            <!-- DPad -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/GamepadButtons/dpads/dpad-all-directions.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Navigate"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Up / Down to browse  ·  Left to go back"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- A -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/GamepadButtons/abxy/a.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Enter / Open"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Enter folder  ·  Play media  ·  Preview file"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- B -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Back"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Exit folder  ·  Close overlay  ·  Stop media"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource XFilesBorderBrush}" Margin="0,0,0,14" />

                            <!-- Media -->
                            <TextBlock Text="MEDIA"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                        FontSize="11" Foreground="{StaticResource XFilesTextMutedBrush}"
                                        Margin="0,0,0,8" />

                            <!-- LB/RB -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/GamepadButtons/lr/button_xbox_digital_bumper_light_1.png"
                                       Width="26" Height="16" Margin="0,0,4,0"
                                       VerticalAlignment="Center" />
                                <Image Source="ms-appx:///Assets/GamepadButtons/lr/button_xbox_digital_bumper_light_2.png"
                                       Width="26" Height="16" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Seek 5s"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Back / Forward while media plays"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- LT/RT -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/GamepadButtons/lr/button_xbox_analog_trigger_light_1.png"
                                       Width="16" Height="26" Margin="0,0,4,0"
                                       VerticalAlignment="Center" />
                                <Image Source="ms-appx:///Assets/GamepadButtons/lr/button_xbox_analog_trigger_light_2.png"
                                       Width="16" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Accelerating seek"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Hold longer = seek faster"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- L/R Stick -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Image Source="ms-appx:///Assets/GamepadButtons/analog/button_xbox_analog_l.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Volume"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Left / Right stick adjusts volume"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource XFilesBorderBrush}" Margin="0,0,0,14" />

                            <!-- File ops -->
                            <TextBlock Text="ACTIONS"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       FontSize="11" Foreground="{StaticResource XFilesTextMutedBrush}"
                                       Margin="0,0,0,8" />

                            <!-- Y -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/GamepadButtons/abxy/y.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Context Menu"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/fileactionsheet-copy-48.png"
                                               Width="14" Height="14" Margin="0,0,3,0" Opacity="0.6" />
                                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/fileactionsheet-move-48.png"
                                               Width="14" Height="14" Margin="0,0,3,0" Opacity="0.6" />
                                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/fileactionsheet-rename-48.png"
                                               Width="14" Height="14" Margin="0,0,3,0" Opacity="0.6" />
                                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/fileactionsheet-delete-48.png"
                                               Width="14" Height="14" Margin="0,0,3,0" Opacity="0.6" />
                                        <Image Source="ms-appx:///Assets/Views/FileActionSheet/fileactionsheet-extract-48.png"
                                               Width="14" Height="14" Opacity="0.6" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- X -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Image Source="ms-appx:///Assets/GamepadButtons/abxy/x.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Refresh"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Reload current directory"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Start -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <Image Source="ms-appx:///Assets/GamepadButtons/system/xboxl_menu.png"
                                       Width="26" Height="26" Margin="0,0,10,0"
                                       VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Start Menu"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="13" Foreground="#CCFFFFFF" />
                                    <TextBlock Text="Settings, About, Close app"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="10" Foreground="{StaticResource XFilesTextDimBrush}"
                                               Margin="0,1,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER (legend + status) ═══ -->
        <Grid Grid.Row="2" Background="#284325" Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Legend: button images + labels -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- A -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/abxy/a.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock x:Name="FooterALabel"
                               Text="Enter"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- B -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock x:Name="FooterBLabel"
                               Text="Back"
