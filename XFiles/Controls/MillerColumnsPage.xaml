<Page
    x:Class="XFiles.Controls.MillerColumnsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XFiles.Controls"
    Background="#0D0D0D"
    IsTabStop="True">

    <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*" />
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="45*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Parent column (left) -->
        <Grid Grid.Column="0" Grid.Row="0" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                x:Name="ParentHeader"
                Text=""
                Foreground="#33AA55"
                FontSize="20"
                Padding="8,8,8,4" />

            <ListView Grid.Row="1"
                x:Name="ParentList"
                Padding="0"
                Style="{StaticResource RetroListViewStyle}"
                ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                IsHitTestVisible="False"
                Opacity="0.6">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Image Source="{Binding Icon}"
                                   Width="18" Height="18"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#888888"
                                       FontSize="16"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2"
                x:Name="ParentStatus"
                Text=""
                Foreground="#444444"
                FontSize="14"
                Padding="12,8,12,8" />
        </Grid>

        <!-- Current column (center) — has focus -->
        <Grid Grid.Column="1" Grid.Row="0" Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                x:Name="CurrentHeader"
                Text=""
                Foreground="#33AA55"
                FontSize="20"
                Padding="8,8,8,4" />

            <controls:RetroListView Grid.Row="1"
                x:Name="CurrentList"
                Padding="0"
                Style="{StaticResource RetroListViewStyle}"
                ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                SelectionChanged="CurrentList_SelectionChanged"
                KeyDown="CurrentList_KeyDown">
                <controls:RetroListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Image Source="{Binding Icon}"
                                   Width="20" Height="20"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#E0E0E0"
                                       FontSize="18"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SizeDisplay}"
                                       Foreground="#555555"
                                       FontSize="14"
                                       HorizontalAlignment="Right"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </controls:RetroListView.ItemTemplate>
            </controls:RetroListView>

            <!-- Loading indicator for current column -->
            <StackPanel Grid.Row="1"
                x:Name="CurrentLoading"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Visibility="Collapsed">
                <ProgressRing IsActive="True" Width="32" Height="32" />
                <TextBlock Text="Loading..."
                           Foreground="#555555"
                           FontSize="16"
                           Margin="0,8,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <TextBlock Grid.Row="2"
                x:Name="CurrentStatus"
                Text=""
                Foreground="#666666"
                FontSize="14"
                Padding="12,8,12,8" />
        </Grid>

        <!-- Preview column (right) -->
        <Grid Grid.Column="2" Grid.Row="0" Background="#111111">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                x:Name="PreviewHeader"
                Text=""
                Foreground="#33AA55"
                FontSize="20"
                Padding="8,8,8,4" />

            <!-- Preview content: folder listing -->
            <ListView Grid.Row="1"
                x:Name="PreviewList"
                Padding="0"
                Style="{StaticResource RetroListViewStyle}"
                ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                IsHitTestVisible="False"
                Opacity="0.7">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <Image Source="{Binding Icon}"
                                   Width="18" Height="18"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}"
                                       Foreground="#999999"
                                       FontSize="16"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Preview content: text file (plain) -->
            <ScrollViewer Grid.Row="1"
                x:Name="PreviewTextScroll"
                Visibility="Collapsed"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Auto"
                Padding="12,8">
                <TextBlock x:Name="PreviewTextBlock"
                    FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                    FontSize="12"
                    Foreground="#CCCCCC"
                    TextWrapping="Wrap"
                    IsTextSelectionEnabled="True" />
            </ScrollViewer>

            <!-- Preview content: source code (syntax highlighted) -->
            <WebView Grid.Row="1"
                x:Name="PreviewCodeView"
                DefaultBackgroundColor="#111111"
                Visibility="Collapsed" />

            <!-- Preview content: image file -->
            <Grid Grid.Row="1"
                x:Name="PreviewImagePanel"
                Visibility="Collapsed"
                Background="#111111">
                <Image x:Name="PreviewImage"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Stretch="Uniform" />
            </Grid>

            <!-- Preview content: error -->
            <Grid Grid.Row="1"
                x:Name="PreviewErrorPanel"
                Visibility="Collapsed">
                <TextBlock x:Name="PreviewErrorText"
                    Foreground="#CC4444"
                    FontSize="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    Padding="16" />
            </Grid>

            <!-- Preview content: unsupported file type -->
            <Grid Grid.Row="1"
                x:Name="PreviewUnsupportedPanel"
                Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="PreviewUnsupportedType"
                        Foreground="#666666"
                        FontSize="18"
                        HorizontalAlignment="Center" />
                    <TextBlock x:Name="PreviewUnsupportedSize"
                        Foreground="#444444"
                        FontSize="14"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,0" />
                </StackPanel>
            </Grid>

            <TextBlock Grid.Row="2"
                x:Name="PreviewStatus"
                Text=""
                Foreground="#444444"
                FontSize="14"
                Padding="12,8,12,8" />
        </Grid>

        <!-- Footer -->
        <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Background="#1A1A1A" Padding="20,10">
            <TextBlock Text="A/Right: Enter | B/Left: Back | D-Pad: Navigate"
                       Foreground="#555555"
                       FontSize="14"
                       HorizontalAlignment="Center" />
        </Grid>
    </Grid>
</Page>
