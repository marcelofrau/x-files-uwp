                    <TextBlock Text="Vol"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12" Margin="0,2,0,0"
                               Foreground="#99FFFFFF" VerticalAlignment="Center" />
