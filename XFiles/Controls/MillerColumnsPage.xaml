<Page
    x:Class="XFiles.Controls.MillerColumnsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XFiles.Controls"
    Background="#0D1117"
    IsTabStop="True">

    <Grid>
        <!-- Main layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Background="#1A1D23" Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Source="ms-appx:///Assets/logo.png"
                   Height="24"
                   Margin="0,0,10,0"
                   VerticalAlignment="Center" />

            <TextBlock Grid.Column="2"
                       x:Name="VersionText"
                       Text=""
                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                       FontSize="12"
                       Foreground="{StaticResource XFilesTextMutedBrush}"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- ═══ COLUMNS ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*" />
                <ColumnDefinition Width="35*" />
                <ColumnDefinition Width="45*" />
            </Grid.ColumnDefinitions>

            <!-- Parent column (left) -->
            <Grid Grid.Column="0" Background="#0F1318">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                    x:Name="ParentHeader"
                    Text=""
                    Foreground="{StaticResource XFilesAccentBrush}"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                    FontSize="14"
                    Padding="12,8,12,4" />

                <ListView Grid.Row="1"
                    x:Name="ParentList"
                    Padding="0"
                    Style="{StaticResource RetroListViewStyle}"
                    ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                    IsHitTestVisible="False"
                    Opacity="0.6">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Image Source="{Binding Icon}"
                                       Width="18" Height="18"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource XFilesTextMutedBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Grid.Row="2"
                    x:Name="ParentStatus"
                    Text=""
                    Foreground="{StaticResource XFilesTextDimBrush}"
                    FontSize="12"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                    Padding="12,6,12,6" />
            </Grid>

            <!-- Current column (center) — has focus -->
            <Grid Grid.Column="1" Background="#141820">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                    x:Name="CurrentHeader"
                    Text=""
                    Foreground="{StaticResource XFilesAccentBrush}"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                    FontSize="14"
                    Padding="12,8,12,4" />

                <controls:RetroListView Grid.Row="1"
                    x:Name="CurrentList"
                    Padding="0"
                    Style="{StaticResource RetroListViewStyle}"
                    ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                    SelectionChanged="CurrentList_SelectionChanged"
                    KeyDown="CurrentList_KeyDown">
                    <controls:RetroListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Image Source="{Binding Icon}"
                                       Width="20" Height="20"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource XFilesForegroundBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="15"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SizeDisplay}"
                                           Foreground="{StaticResource XFilesTextDimBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="12"
                                           HorizontalAlignment="Right"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </controls:RetroListView.ItemTemplate>
                </controls:RetroListView>

                <!-- Loading indicator for current column -->
                <StackPanel Grid.Row="1"
                    x:Name="CurrentLoading"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
                    <ProgressRing IsActive="True" Width="32" Height="32"
                                  Foreground="{StaticResource XFilesAccentBrush}" />
                    <TextBlock Text="Loading..."
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="14"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                    x:Name="CurrentStatus"
                    Text=""
                    Foreground="{StaticResource XFilesTextDimBrush}"
                    FontSize="12"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                    Padding="12,6,12,6" />
            </Grid>

            <!-- Preview column (right) -->
            <Grid Grid.Column="2" Background="#0F1318">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                    x:Name="PreviewHeader"
                    Text=""
                    Foreground="{StaticResource XFilesAccentBrush}"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                    FontSize="14"
                    Padding="12,8,12,4" />

                <!-- Preview content: folder listing -->
                <ListView Grid.Row="1"
                    x:Name="PreviewList"
                    Padding="0"
                    Style="{StaticResource RetroListViewStyle}"
                    ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                    IsHitTestVisible="False"
                    Opacity="0.7">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Image Source="{Binding Icon}"
                                       Width="18" Height="18"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource XFilesTextMutedBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="14"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Preview content: text file (plain) -->
                <ScrollViewer Grid.Row="1"
                    x:Name="PreviewTextScroll"
                    Visibility="Collapsed"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Auto"
                    Padding="12,8">
                    <TextBlock x:Name="PreviewTextBlock"
                        FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                        FontSize="12"
                        Foreground="#CCCCCC"
                        TextWrapping="Wrap"
                        IsTextSelectionEnabled="True" />
                </ScrollViewer>

                <!-- Preview content: source code (syntax highlighted) -->
                <WebView Grid.Row="1"
                    x:Name="PreviewCodeView"
                    DefaultBackgroundColor="#0F1318"
                    Visibility="Collapsed" />

                <!-- Preview content: image file -->
                <Grid Grid.Row="1"
                    x:Name="PreviewImagePanel"
                    Visibility="Collapsed"
                    Background="#0F1318">
                    <Image x:Name="PreviewImage"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Stretch="Uniform" />
                </Grid>

                <!-- Preview content: error -->
                <Grid Grid.Row="1"
                    x:Name="PreviewErrorPanel"
                    Visibility="Collapsed">
                    <TextBlock x:Name="PreviewErrorText"
                        Foreground="{StaticResource XFilesDangerBrush}"
                        FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                        FontSize="14"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        TextWrapping="Wrap"
                        Padding="16" />
                </Grid>

                <!-- Preview content: unsupported file type -->
                <Grid Grid.Row="1"
                    x:Name="PreviewUnsupportedPanel"
                    Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="PreviewUnsupportedType"
                            Foreground="{StaticResource XFilesTextMutedBrush}"
                            FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                            FontSize="16"
                            HorizontalAlignment="Center" />
                        <TextBlock x:Name="PreviewUnsupportedSize"
                            Foreground="{StaticResource XFilesTextDimBrush}"
                            FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                    x:Name="PreviewStatus"
                    Text=""
                    Foreground="{StaticResource XFilesTextDimBrush}"
                    FontSize="12"
                    FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                    Padding="12,6,12,6" />
            </Grid>
        </Grid>

        <!-- ═══ FOOTER (legend + status) ═══ -->
        <Grid Grid.Row="2" Background="#1A1D23" Padding="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Legend: button images + labels -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- A -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/a-1.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Enter"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- B -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/b-1.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Back"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- X -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/x-1.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Refresh"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- Y -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/y-1.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Menu"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <!-- Start -->
                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                    <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/menu.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock Text="Settings"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Foreground="{StaticResource XFilesTextDimBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- Status: item count + loading -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ProgressRing x:Name="FooterSpinner"
                              IsActive="False"
                              Width="14" Height="14"
                              Margin="0,0,6,0"
                              Foreground="{StaticResource XFilesAccentBrush}" />
                <TextBlock x:Name="FooterItemCount"
                           Text=""
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                           FontSize="12"
                           Foreground="{StaticResource XFilesTextDimBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
        </Grid>

        <!-- Dialog overlays (on top of everything) -->
        <controls:FileActionSheet x:Name="FileActionSheetControl" />
        <controls:ConfirmDialog x:Name="ConfirmDialogControl" />
        <controls:InputDialog x:Name="InputDialogControl" />
    </Grid>
</Page>
