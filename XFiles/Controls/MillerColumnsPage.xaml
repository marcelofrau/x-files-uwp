                <SolidColorBrush Color="#E60D1117" />
            </Grid.Background>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="600" Width="600"
                    Background="#FF1A1D23" BorderBrush="#FF2A2D33" BorderThickness="1"
                    CornerRadius="8" Padding="32,28">
                <StackPanel>
                    <TextBlock x:Name="PlaceholderTitleText"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                               FontSize="22" Foreground="#FF93C43C"
                               Text="" Margin="0,0,0,8" />
                    <TextBlock x:Name="PlaceholderSubtitleText"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="14" Foreground="#99FFFFFF"
                               TextWrapping="Wrap" Text="" Margin="0,0,0,20" />
                    <Border Background="#252830" Height="1" Margin="0,0,0,16" />
                    <TextBlock x:Name="PlaceholderBodyText"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="13" Foreground="#66FFFFFF"
                               TextWrapping="Wrap" Text="" />
                    <TextBlock Text="B — Back"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="11" Foreground="#44FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,28,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Error overlay -->
        <Grid x:Name="ErrorOverlay" Visibility="Collapsed"
              Grid.Row="0" Grid.RowSpan="3"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.Background>
                <SolidColorBrush Color="#CC000000" />
            </Grid.Background>
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="700" MaxHeight="480" Width="700" Height="480"
                    Background="#FF1A1D23" BorderBrush="#FFE04848" BorderThickness="2"
                    CornerRadius="8">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Title bar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE783;" FontSize="22"
                                  Foreground="#FFE04848" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBlock x:Name="ErrorTitleText" Grid.Column="1"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                   FontSize="18" Foreground="#FFE04848"
                                   VerticalAlignment="Center" Text="Error" />
                        <Button x:Name="BtnErrorClose" Grid.Column="2"
                                Background="Transparent" BorderThickness="0"
                                Padding="8,4" Click="OnErrorCloseClick">
                            <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="#99FFFFFF" />
                        </Button>
                    </Grid>

                    <!-- Description -->
                    <TextBlock x:Name="ErrorDescriptionText" Grid.Row="1"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="13" Foreground="#CCFFFFFF"
                               TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="An unexpected error occurred." />

                    <!-- Details console -->
                    <Border Grid.Row="2" Background="#FF0D1117" CornerRadius="4" Padding="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ErrorDetailsText"
                                       FontFamily="ms-appx:///Assets/Fonts/Inconsolata-Regular.ttf#Inconsolata"
                                       FontSize="11" Foreground="#FF2ECC71"
                                       TextWrapping="Wrap" Padding="8,6"
                                       Text="" />
                        </ScrollViewer>
                    </Border>

                    <!-- Buttons -->
                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnErrorCopy" Grid.Column="0"
                                Background="#FF254220" Foreground="#FF93C43C"
                                BorderBrush="#FF4A6220" BorderThickness="1"
                                Padding="16,6" Click="OnErrorCopyClick">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE8C8;" FontSize="14" Margin="0,0,6,0"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Copy Error" FontSize="12"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnErrorReport" Grid.Column="2"
                                Background="#FF254220" Foreground="#FF93C43C"
                                BorderBrush="#FF4A6220" BorderThickness="1"
                                Padding="16,6" Click="OnErrorReportClick">
                            <StackPanel Orientation="Horizontal">
                                <FontIcon Glyph="&#xE77D;" FontSize="14" Margin="0,0,6,0"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Report to GitHub" FontSize="12"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
