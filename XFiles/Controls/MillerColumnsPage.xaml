                        CornerRadius="0,0,8,8" Padding="32,0,32,28">
                    <StackPanel Spacing="0">
                        <!-- Version + Author -->
                        <TextBlock x:Name="AboutVersionText"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                   FontSize="15" Foreground="#FF93C43C"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Marcelo Frau"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="12" Foreground="#888888"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0" />
                        <TextBlock Text="GPL-3.0-only"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="11" Foreground="#FFD4A017"
                                   HorizontalAlignment="Center"
                                   Margin="0,2,0,0" />

