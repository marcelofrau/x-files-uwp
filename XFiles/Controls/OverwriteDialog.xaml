<UserControl
    x:Class="XFiles.Controls.OverwriteDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117" Tapped="OnOverlayTapped" KeyDown="OnKeyDown"
          IsHitTestVisible="True">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="480"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24,20">

            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Image Source="ms-appx:///Assets/Views/AlertDialog/alert-warning-48.png"
                           Width="40" Height="40"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center" />
                    <TextBlock x:Name="MessageText"
                               Foreground="{StaticResource XFilesForegroundBrush}"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="15"
                               TextWrapping="Wrap"
                               MaxWidth="380"
                               VerticalAlignment="Center"
                               Text="" />
                </StackPanel>

                <StackPanel x:Name="ButtonsPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">

                    <!-- OVERWRITE: A button -->
                    <Button x:Name="OverwriteButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnOverwriteClicked"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/abxy/a.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="OVERWRITE"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- OVERWRITE ALL: Y button -->
                    <Button x:Name="OverwriteAllButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnOverwriteAllClicked"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/abxy/y.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="ALL"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- SKIP: B button -->
                    <Button x:Name="SkipButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnSkipClicked">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="SKIP"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
