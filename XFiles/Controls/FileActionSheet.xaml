<UserControl
    x:Class="XFiles.Controls.FileActionSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#E60D1117" Tapped="OnOverlayTapped">
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: file icon + name (right-aligned, meets center) -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,0">
                <Image x:Name="FileIconImage"
                       Width="96" Height="96"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16"
                       Stretch="Uniform" />
                <TextBlock x:Name="FileNameText"
                           Foreground="#FFE0E0E0"
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                           FontSize="22"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="360"
                           HorizontalAlignment="Center"
                           Text="" />
            </StackPanel>

            <!-- Right: action list (left-aligned, meets center) -->
            <Border Grid.Column="1"
                    Background="#1A1D23"
                    BorderBrush="#2A2D33"
                    BorderThickness="1"
                    CornerRadius="8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Left"
                    Padding="0,12"
                    MinWidth="280">

                <StackPanel>
                    <TextBlock Text="actions"
                               Foreground="#66FFFFFF"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="11"
                               Padding="20,4,20,8" />

                    <Border Background="#252830" Height="1" Margin="12,0,12,4" />

                    <ListView x:Name="ActionList"
                              Style="{StaticResource RetroListViewStyle}"
                              ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                              SelectionChanged="OnActionSelectionChanged"
                              ContainerContentChanging="OnActionContainerChanging">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Padding="16,12">
                                    <Image Source="{Binding IconPath}"
                                           Width="24" Height="24"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="18"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Background="#252830" Height="1" Margin="12,4,12,0" />

                    <!-- B button hint -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Padding="0,10,0,4">
                        <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/b-1.png"
                               Width="18" Height="18" Margin="0,0,4,0"
                               VerticalAlignment="Center" />
                        <TextBlock Text="Back"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="12"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource XFilesTextMutedBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
