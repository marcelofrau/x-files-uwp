<UserControl
    x:Class="XFiles.Controls.FileActionSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117" Tapped="OnOverlayTapped">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="6"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,50"
                Padding="0,8"
                MinWidth="280"
                MaxWidth="360">

            <StackPanel>
                <!-- File name header -->
                <TextBlock x:Name="FileNameText"
                           Foreground="{StaticResource XFilesTextDimBrush}"
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                           FontSize="12"
                           Padding="16,8,16,4"
                           Text=""
                           TextTrimming="CharacterEllipsis" />

                <!-- Actions list -->
                <ListView x:Name="ActionList"
                          Style="{StaticResource RetroListViewStyle}"
                          ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                          SelectionChanged="OnActionSelectionChanged"
                          KeyDown="OnActionListKeyDown">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Padding="12,8">
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{Binding IconBrush}"
                                           Width="24"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding Label}"
                                           Foreground="{StaticResource XFilesForegroundBrush}"
                                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                           FontSize="15"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
