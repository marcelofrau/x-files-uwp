<UserControl
    x:Class="XFiles.Controls.VideoTrackMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="8"
                MaxWidth="420"
                MinWidth="320"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0,12">

            <StackPanel>
                <!-- Level 1: Options list -->
                <StackPanel x:Name="OptionsPanel">
                    <TextBlock Text="options"
                               Foreground="#66FFFFFF"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="11"
                               Padding="20,4,20,8" />

                    <Border Background="#252830" Height="1" Margin="12,0,12,4" />

                    <ListView x:Name="OptionsList"
                              Style="{StaticResource RetroListViewStyle}"
                              ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                              SelectionChanged="OnOptionSelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Padding="16,10">
                                    <Image Source="{Binding IconPath}"
                                           Width="20" Height="20"
                                           VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Label}"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="16"
                                               Foreground="{StaticResource XFilesForegroundBrush}"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Background="#252830" Height="1" Margin="12,4,12,0" />
                </StackPanel>

                <!-- Level 2: Subtitle detail -->
                <StackPanel x:Name="SubtitlesPanel" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Padding="20,4,20,8">
                        <TextBlock Text="&#xE72B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="#66FFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="subtitles"
                                   Foreground="#66FFFFFF"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="#252830" Height="1" Margin="12,0,12,4" />

                    <ListView x:Name="SubtitleList"
                              Style="{StaticResource RetroListViewStyle}"
                              ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                              SelectionChanged="OnSubtitleSelectionChanged"
                              ContainerContentChanging="OnSubtitleContainerChanging">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Padding="16,10">
                                    <Image Source="{Binding IndicatorIcon}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsActive}" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="16"
                                               Foreground="{StaticResource XFilesForegroundBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               MaxWidth="300"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="ACTIVE"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                               FontSize="10"
                                               Foreground="{StaticResource XFilesAccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               Visibility="{Binding IsActive}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Background="#252830" Height="1" Margin="12,4,12,0" />
                </StackPanel>

                <!-- Level 2: Audio detail -->
                <StackPanel x:Name="AudioPanel" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Padding="20,4,20,8">
                        <TextBlock Text="&#xE72B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="#66FFFFFF"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="audio tracks"
                                   Foreground="#66FFFFFF"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Background="#252830" Height="1" Margin="12,0,12,4" />

                    <ListView x:Name="AudioList"
                              Style="{StaticResource RetroListViewStyle}"
                              ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                              SelectionChanged="OnAudioSelectionChanged"
                              ContainerContentChanging="OnAudioContainerChanging">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Padding="16,10">
                                    <Image Source="{Binding IndicatorIcon}"
                                           Width="16" Height="16"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsActive}" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                               FontSize="16"
                                               Foreground="{StaticResource XFilesForegroundBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               MaxWidth="300"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="ACTIVE"
                                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                               FontSize="10"
                                               Foreground="{StaticResource XFilesAccentBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               Visibility="{Binding IsActive}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border Background="#252830" Height="1" Margin="12,4,12,0" />
                </StackPanel>

                <!-- B button hint (shared) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Padding="0,10,0,4">
                    <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                           Width="18" Height="18" Margin="0,0,4,0"
                           VerticalAlignment="Center" />
                    <TextBlock x:Name="BackHintText"
                               Text="Back"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="12"
                               Margin="0,3,0,0"
                               Foreground="{StaticResource XFilesTextMutedBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
