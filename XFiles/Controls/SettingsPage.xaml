<UserControl
    x:Class="XFiles.Controls.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:XFiles.Controls"
    Visibility="Collapsed">

    <Grid>
        <Grid x:Name="Overlay" Background="#CC0D1117" Tapped="OnOverlayTapped">
            <Border Background="#1A1D23"
                    BorderBrush="#2A2D33"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0,12"
                    MinWidth="420"
                    MaxWidth="520">

                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="Settings"
                               Foreground="#B0D8A0"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                               FontSize="16"
                               Padding="20,12,20,8" />

                    <Border Background="#252830" Height="1" Margin="12,0,12,4" />

                    <!-- Stats line -->
                    <TextBlock x:Name="CacheStatsText"
                               Text=""
                               Foreground="#666666"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="11"
                               Padding="20,2,20,6" />

                    <!-- Selectable menu items -->
                    <ListView x:Name="SettingsList"
                              Style="{StaticResource RetroListViewStyle}"
                              ItemContainerStyle="{StaticResource RetroListViewItemStyle}"
                              SelectionChanged="OnSelectionChanged"
                              ContainerContentChanging="OnContainerChanging">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Padding="16,12">
                                    <Image Source="{Binding IconPath}"
                                           Width="40" Height="40"
                                           VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                                        <TextBlock Text="{Binding Label}"
                                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                                   FontSize="20" />
                                        <TextBlock Text="{Binding Description}"
                                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                                   FontSize="12"
                                                   Foreground="#666666"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Footer hint -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Padding="0,10,0,4">
                        <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                               Width="18" Height="18" Margin="0,0,4,0"
                               VerticalAlignment="Center" />
                        <TextBlock Text="Back"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                                   FontSize="12"
                                   Margin="0,3,0,0"
                                   Foreground="{StaticResource XFilesTextMutedBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <controls:AlertDialog x:Name="AlertDialogControl" />
    </Grid>
</UserControl>
