<UserControl
    x:Class="XFiles.Controls.AlertDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117" Tapped="OnOverlayTapped" KeyDown="OnKeyDown"
          IsHitTestVisible="True">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="440"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24,20">

            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Image x:Name="TypeIcon"
                           Width="40" Height="40"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center" />
                    <TextBlock x:Name="MessageText"
                               Foreground="{StaticResource XFilesForegroundBrush}"
                               FontFamily="ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium"
                               FontSize="15"
                               TextWrapping="Wrap"
                               MaxWidth="340"
                               VerticalAlignment="Center"
                               Text="" />
                </StackPanel>

                <StackPanel x:Name="ButtonsPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0">

                    <!-- OK / YES: A button -->
                    <Button x:Name="YesButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnYesClicked"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/abxy/a.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock x:Name="YesLabel"
                                       Text="OK"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- NO / CANCEL: B button (hidden in OK-only mode) -->
                    <Button x:Name="NoButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnNoClicked"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/abxy/b.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock x:Name="NoLabel"
                                       Text="NO"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
