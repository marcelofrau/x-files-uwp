<UserControl
    x:Class="XFiles.Controls.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117" Tapped="OnOverlayTapped">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24,20">

            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Foreground="{StaticResource XFilesAccentBrush}"
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                           FontSize="15"
                           Margin="0,0,0,12"
                           Text="" />

                <TextBox x:Name="InputBox"
                         FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                         FontSize="15"
                         Foreground="{StaticResource XFilesForegroundBrush}"
                         Background="#0F1318"
                         BorderBrush="{StaticResource XFilesInputBorderBrush}"
                         BorderThickness="1"
                         Padding="8,6"
                         GotFocus="OnInputGotFocus"
                         KeyDown="OnInputKeyDown" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">

                    <!-- OK: A button image + text -->
                    <Button x:Name="OkButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnOkClicked"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/a-1.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="OK"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- CANCEL: B button image + text -->
                    <Button x:Name="CancelButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnCancelClicked">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="ms-appx:///Assets/GamepadButtons/xboxone-dark/b-1.png"
                                   Width="18" Height="18" Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="CANCEL"
                                       FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                       Foreground="{StaticResource XFilesForegroundBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
