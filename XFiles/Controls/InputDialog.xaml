<UserControl
    x:Class="XFiles.Controls.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Visibility="Collapsed">

    <Grid x:Name="Overlay" Background="#CC0D1117" Tapped="OnOverlayTapped">
        <Border Background="#1A1D23"
                BorderBrush="#2A2D33"
                BorderThickness="1"
                CornerRadius="6"
                MaxWidth="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="24,20">

            <StackPanel>
                <TextBlock x:Name="TitleText"
                           Foreground="{StaticResource XFilesAccentBrush}"
                           FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                           FontSize="15"
                           Margin="0,0,0,12"
                           Text="" />

                <TextBox x:Name="InputBox"
                         FontFamily="ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata"
                         FontSize="15"
                         Foreground="{StaticResource XFilesForegroundBrush}"
                         Background="#0F1318"
                         BorderBrush="{StaticResource XFilesInputBorderBrush}"
                         BorderThickness="1"
                         Padding="8,6"
                         GotFocus="OnInputGotFocus"
                         KeyDown="OnInputKeyDown" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,16,0,0">

                    <Button x:Name="OkButton"
                            Style="{StaticResource ConfirmDialogButton}"
                            Click="OnOkClicked">
                        <TextBlock Text="OK"
                                   FontFamily="ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium"
                                   Foreground="{StaticResource XFilesForegroundBrush}" />
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
