<Page
    x:Class="XFiles.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:XFiles"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!--
        Scaffold placeholder. Real 3-column Miller layout (Parent | Current | Preview)
        is introduced in Phase 4 (see docs/ROADMAP.md). This page currently only proves
        the app boots and renders on Xbox (Phase 1 goal).
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.75*" />
            <ColumnDefinition Width="2.25*" />
        </Grid.ColumnDefinitions>

        <!-- Placeholder columns: Parent / Current / Preview -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="Gray">
            <TextBlock Text="Parent" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" />
        </Border>
        <Border Grid.Column="1" BorderThickness="0,0,1,0" BorderBrush="Gray">
            <TextBlock Text="X-Files" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="32" />
        </Border>
        <Border Grid.Column="2">
            <TextBlock Text="Preview" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" />
        </Border>
    </Grid>
</Page>
