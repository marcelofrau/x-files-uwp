<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        X-Files Theme — dark green accent variant.
        Selection: bright green bg (#93C43C) + dark text (#252830).
        Headers/footers: dark green (#284325).
    -->

    <!-- ═══ Brushes ═══ -->
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="XFilesBackgroundBrush" Color="#0D1117" />
    <SolidColorBrush x:Key="XFilesSurfaceBrush" Color="#1A1D23" />
    <SolidColorBrush x:Key="XFilesSurfaceAltBrush" Color="#252830" />
    <SolidColorBrush x:Key="XFilesSurfaceHoverBrush" Color="#2F333A" />
    <SolidColorBrush x:Key="XFilesCardBgBrush" Color="#1E2128" />
    <SolidColorBrush x:Key="XFilesSidebarBgBrush" Color="#0F1A0F" />
    <SolidColorBrush x:Key="XFilesInputBgBrush" Color="#0F1A0F" />

    <!-- Accent (green) -->
    <SolidColorBrush x:Key="XFilesAccentBrush" Color="#93C43C" />
    <SolidColorBrush x:Key="XFilesAccentDimBrush" Color="#7AA832" />
    <SolidColorBrush x:Key="XFilesAccentGlowBrush" Color="#B0E050" />
    <SolidColorBrush x:Key="XFilesAccentHoverDarkBrush" Color="#4A6220" />

    <!-- Text -->
    <SolidColorBrush x:Key="XFilesForegroundBrush" Color="#F0F0F0" />
    <SolidColorBrush x:Key="XFilesTextMutedBrush" Color="#8B8D91" />
    <SolidColorBrush x:Key="XFilesTextDimBrush" Color="#5A5C60" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="XFilesSelectedBackgroundBrush" Color="#93C43C" />
    <SolidColorBrush x:Key="XFilesSelectedTextBrush" Color="#252830" />
    <SolidColorBrush x:Key="XFilesSelectedUnfocusedBrush" Color="#1E2A12" />
    <SolidColorBrush x:Key="XFilesBorderBrush" Color="#2A2D33" />
    <SolidColorBrush x:Key="XFilesDangerBrush" Color="#E74C3C" />
    <SolidColorBrush x:Key="XFilesSuccessBrush" Color="#2ECC71" />
    <SolidColorBrush x:Key="XFilesWarningBrush" Color="#F39C12" />
    <SolidColorBrush x:Key="XFilesInputBorderBrush" Color="#4A6220" />
    <SolidColorBrush x:Key="XFilesInputBorderHoverBrush" Color="#7AA832" />

    <!-- Header/footer green -->
    <SolidColorBrush x:Key="XFilesHeaderBgBrush" Color="#284325" />
    <SolidColorBrush x:Key="XFilesFooterBgBrush" Color="#284325" />

    <!-- Title gradient (green) -->
    <LinearGradientBrush x:Key="XFilesTitleGradient" StartPoint="0%,0%" EndPoint="100%,0%">
        <GradientStop Color="#7AA832" Offset="0" />
        <GradientStop Color="#93C43C" Offset="1" />
    </LinearGradientBrush>

    <!-- ═══ Typography ═══ -->
    <FontFamily x:Key="XFilesTitleFont">ms-appx:///Assets/Fonts/Oxanium-Bold.ttf#Oxanium</FontFamily>
    <FontFamily x:Key="XFilesBodyFont">ms-appx:///Assets/Fonts/Oxanium-Regular.ttf#Oxanium</FontFamily>
    <FontFamily x:Key="XFilesMonoFontFamily">ms-appx:///Assets/Inconsolata-Regular.ttf#Inconsolata</FontFamily>

    <!-- ═══ ListView ═══ -->
    <Style x:Key="RetroListViewStyle" TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="SelectionMode" Value="Single" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="FontFamily" Value="{StaticResource XFilesBodyFont}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListView">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="ScrollViewer"
                                      HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                      VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                      VerticalScrollMode="Enabled">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ ListViewItem ═══ -->
    <Style x:Key="RetroListViewItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="FocusVisualMargin" Value="0" />
        <Setter Property="Foreground" Value="#F0F0F0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="FontFamily" Value="{StaticResource XFilesBodyFont}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <ListViewItemPresenter x:Name="Presenter"
                        Content="{TemplateBinding Content}"
                        HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="Center"
                        Padding="{TemplateBinding Padding}"
                        SelectedBackground="#93C43C"
                        SelectedForeground="#1A1D23"
                        PointerOverBackground="#1E2A12"
                        SelectedPointerOverBackground="#7AA832"
                        SelectionCheckMarkVisualEnabled="False"
                        FocusVisualMargin="0"
                        CheckBrush="Transparent"
                        CheckBoxBrush="Transparent"
                        ContentMargin="0"
                        DisabledOpacity="0.4" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══ Button (dialog/overlay) ═══ -->
    <Style x:Key="ConfirmDialogButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource XFilesSurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{StaticResource XFilesForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource XFilesBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{StaticResource XFilesBodyFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinWidth" Value="80" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}" />
                    </Border>
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Target="Root.Background" Value="{StaticResource XFilesAccentHoverDarkBrush}" />
                                    <Setter Target="Root.BorderBrush" Value="{StaticResource XFilesAccentDimBrush}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Target="Root.Background" Value="{StaticResource XFilesAccentBrush}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Disabled">
                                <VisualState.Setters>
                                    <Setter Target="Root.Opacity" Value="0.4" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
