<Application
    x:Class="XFiles.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Custom control templates / theme brushes. See docs/UI-THEMING.md. -->
                <ResourceDictionary Source="Theming/RetroTheme.xaml" />

                <!-- Override system selection/highlight brushes for dark theme -->
                <ResourceDictionary>
                    <!-- Selection background for ListView items -->
                    <SolidColorBrush x:Key="SystemControlHighlightListAccentLowBrush" Color="#2A1F10" />
                    <!-- Pointer-over for ListView items -->
                    <SolidColorBrush x:Key="SystemControlHighlightListHighBrush" Color="#1E1A12" />
                    <SolidColorBrush x:Key="SystemControlHighlightListLowBrush" Color="#1E1A12" />
                    <!-- Text selection -->
                    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#E8851A" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
